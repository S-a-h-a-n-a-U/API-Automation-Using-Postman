              "});\r",
              "\r",
              "pm.test(\"Firstname is correct\", function () {\r",
              "    pm.expect(response.booking.firstname).to.eql(pm.iterationData.get(\"firstname\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Lastname is correct\", function () {\r",
              "    pm.expect(response.booking.lastname).to.eql(pm.iterationData.get(\"lastname\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Total Price is correct\", function () {\r",
              "    pm.expect(response.booking.totalprice).to.eql(pm.iterationData.get(\"totalprice\"));\r",
              "});"
