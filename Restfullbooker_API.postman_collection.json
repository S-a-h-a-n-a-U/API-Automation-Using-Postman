  "item": [
    {
      "name": "Create Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"token\", response.token);\r",
              "\r",
              "pm.test(\"Status Code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Token Generated\", function () {\r",
              "    pm.expect(response.token).to.not.be.undefined;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"admin\",\r\n    \"password\": \"password123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseurl}}/auth",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "auth"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"bookingid\", response.bookingid);\r",
              "\r",
              "pm.test(\"Booking Created Successfully\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Booking ID Generated\", function () {\r",
              "    pm.expect(response.bookingid).to.not.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Firstname is John\", function () {\r",
              "    pm.expect(response.booking.firstname).to.eql(\"John\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\": \"John\",\r\n    \"lastname\": \"Doe\",\r\n    \"totalprice\": 1000,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-08-01\",\r\n        \"checkout\": \"2026-08-05\"\r\n    },\r\n    \"additionalneeds\": \"Breakfast\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseurl}}/booking",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "booking"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Firstname is John\", function () {\r",
              "    pm.expect(response.firstname).to.eql(\"John\");\r",
              "});\r",
              "\r",
              "pm.test(\"Lastname is Doe\", function () {\r",
              "    pm.expect(response.lastname).to.eql(\"Doe\");\r",
              "});\r",
              "\r",
              "pm.test(\"Total Price is 1000\", function () {\r",
              "    pm.expect(response.totalprice).to.eql(1000);\r",
              "});\r",
              "\r",
              "pm.test(\"Deposit Paid is true\", function () {\r",
              "    pm.expect(response.depositpaid).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.test(\"Additional Needs is Breakfast\", function () {\r",
              "    pm.expect(response.additionalneeds).to.eql(\"Breakfast\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseurl}}/booking/{{bookingid}}",
          "host": [
            "{{baseurl}}"
          ],
          "path": [
            "booking",
